# AetherMed Frontend Environment Variables

# The base URL for the AetherMed backend orchestrator API
VITE_API_BASE_URL=http://127.0.0.1:5000/api/v1

# Example production value:
# VITE_API_BASE_URL=https://aethermed-agentic.onrender.com/api/v1

# ---------------------------------------------------------
# OPTIONAL INTEGRATIONS 
# ---------------------------------------------------------

# Feature Flags
# VITE_ENABLE_SSO=false
# VITE_ACTIVATE_EXPERIMENTAL_LLM_AGENT=false
