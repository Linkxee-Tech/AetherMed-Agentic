# AetherMed Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Agent mode:
# - auto: core agents use OpenAI when available, and translation/detection runs OpenAI-first with offline emergency backup
# - offline: force the entire stack to use local heuristic agents only
AETHERMED_AGENT_MODE=auto

# Optional persistence
# MONGODB_URI=mongodb+srv://your-connection-string

# ---------------------------------------------------------
# FUTURE INTEGRATIONS (Nice-to-have for live AI endpoints)
# ---------------------------------------------------------

# LLM Integration (OpenAI)
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL=gpt-5-mini

# EHR / FHIR Server Integration (e.g., Epic, Cerner Sandbox endpoints)
# FHIR_BASE_URL=https://fhir-open.sandboxcerner.com/dstu2/0b8a0111-e8e6-4c26-a91c-5069cbc6b1ca

# Authentication (If adding JWT later)
# JWT_SECRET=your-super-secret-jwt-key
